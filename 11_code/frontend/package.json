{
  "name": "myagent-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "openapi:download": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/download-openapi.ps1",
    "openapi:generate": "npm run openapi:download && openapi-typescript openapi/myagent-openapi.json --output src/api/generated/schema.ts --default-non-nullable=false",
    "openapi:refresh": "npm run openapi:generate"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-query": "5.100.14",
    "antd": "6.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.16.0",
    "reactflow": "11.11.4",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  }
}
